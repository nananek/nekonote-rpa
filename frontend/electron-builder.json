{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.nekonote.app",
  "productName": "Nekonote",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*",
    "node_modules/node-pty/**/*"
  ],
  "extraResources": [
    {
      "from": "../backend/dist/nekonote-engine",
      "to": "engine",
      "filter": ["**/*"]
    },
    {
      "from": "../CLAUDE.md",
      "to": "CLAUDE.md"
    }
  ],
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "zip", "arch": ["x64"] }
    ],
    "icon": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerLanguages": ["ja"],
    "language": "1041",
    "installerIcon": null,
    "uninstallerIcon": null,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Nekonote"
  },
  "publish": {
    "provider": "github",
    "owner": "nananek",
    "repo": "nekonote-rpa"
  }
}
